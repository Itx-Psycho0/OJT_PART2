# ===============================
# Server Configuration
# ===============================

PORT=5000
NODE_ENV=development

# ===============================
# Frontend URL (CORS)
# ===============================

CLIENT_URL=http://localhost:3000

# ===============================
# Database
# ===============================

MONGO_URI=mongodb://127.0.0.1:27017/colabs

# ===============================
# Authentication
# ===============================

JWT_SECRET=your_jwt_secret_here

# ===============================
# Redis (Optional - for scaling)
# ===============================

REDIS_URL=redis://127.0.0.1:6379